---
import astroLogoWhite from '../assets/img/logo-wave.png';
import astroImage1 from '../assets/img/bg-hero-1.jpg';
import astroImage2 from '../assets/img/bg-hero-2.jpeg';
import astroImage3 from '../assets/img/bg-hero-3.jpg';
import astroImage4 from '../assets/img/bg-hero-4.jpg';
import astroImage5 from '../assets/img/bg-hero-5.jpg';
import astroImage6 from '../assets/img/bg-hero-6.jpg';
// import astroImage3 from '../assets/img/waveconnect-3.jpg';
// import astroImage4 from '../assets/img/waveconnect-4.jpg';
import logoLinkedin from '../assets/img/logo-linkedin.svg';
import Footer from './Footer.astro';
import HeroText from './HeroText.astro';
import 'swiper/css';
import './styles.css';
const images = [
	{ src: astroImage2.src, caption: 'El ecosistema digital donde la audiencia consume contenido hoy.', place: 'Smart TV con plataformas de streaming' },
  { src: astroImage3.src, caption: 'El papel del dato y las alianzas tecnológicas en los medios.', place: 'Panel de expertos en industria de medios' },
  { src: astroImage4.src, caption: 'Quien controla la atención, controla el negocio.', place: 'El nuevo consumidor digital' },
	{ src: astroImage5.src, caption: 'Reconocimiento en el ecosistema publicitario del sector.', place: 'Evento Teads & Mediarithmic' },
	{ src: astroImage6.src, caption: 'Donde el contenido cobra vida, detrás de las cámaras.', place: 'Backstage TEDx Mondoñedo' },
  { src: astroImage1.src, caption: 'Compartiendo visión sobre el futuro de la industria de los medios.', place: 'TEDx Mondoñedo' },
];
---

<div id="container">
	<nav class="ama-nav">
		<div class="ama-nav-wrapper-container">
				<div class="logo">
					<img src={astroLogoWhite.src} width="150" alt="Wave Connect" />
				</div>
				<div class="ama-nav-wrapper">
					<ul class="ama-sociales">
						<li>
							<a href="https://www.linkedin.com/in/sabela-ruy-diaz/" target="_blank">
								<span class="ama-text-share">Let’s connect</span>
								<span class="ama-icon"><img src={logoLinkedin.src} alt="Linkedin" /></span>
							</a>
						</li>
					</ul>
				</div>
		</div>
	</nav>
	<main class="main">
		<section id="hero" class="hero">
			<HeroText/>
			<div class="hero-image">
				<!-- Desktop: carousel -->
				<div class="carousel-desktop">
					{
						images.map((image, index) => (
							<div class="hero-carrusel" style={`background-image: url(${image.src});`}>
								<div class="ama-overlight"></div>
							</div>
						))
					}
				</div>
				<!-- Mobile: last image only -->
				<div class="mobile-hero-image" style={`background-image: url(${images[images.length - 1].src});`}>
					<div class="ama-overlight"></div>
				</div>
			</div>
		</section>
	</main>
</div>

<Footer />

<script>
let index = 0;
const carousels:any = document.querySelectorAll(".hero-carrusel");
const captions:any = document.querySelectorAll(".caption-image");
const firstImage = new Image();
firstImage.src = carousels[0].style.backgroundImage.replace(/url\("|"\)/g, "");
firstImage.onload = () => {
  captions.forEach((caption:any) => caption.style.display = "block");
	document.querySelectorAll(".caption-image").forEach(caption => {
		caption.classList.add("visible");		
	});
  setInterval(updateCarousel, 6000);
};
function updateCarousel() {
	document.querySelectorAll('.caption-image').forEach((caption:any) => {
		caption.style.opacity = 0;
	})
  carousels.forEach((el:any, i:number) => {
    el.style.opacity = i === index ? "1" : "0";
  });
	const currentCaption:any = document.querySelector('.caption-' + index);
  index = (index + 1) % carousels.length;
	if (currentCaption) currentCaption.style.opacity = 1;
}
</script>
